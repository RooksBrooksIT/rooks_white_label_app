# ICICI Payment Gateway - LIVE Configuration
# DO NOT commit this file with actual values to source control.

# ─── ICICI Live Credentials ───────────────────────────────────────────────────
ICICI_MERCHANT_MID=100000000429484
ICICI_AGGREGATOR_ID=100000000429483
ICICI_TERMINAL_ID=0001

# Merchant Key: download from ICICI Dashboard → Key Management
# https://pgportal.icicibank.com/v2/pgmp/login
ICICI_MERCHANT_KEY=<PASTE_LIVE_KEY_HERE>

# Leave empty if not using UPI VPA flow
ICICI_MERCHANT_VPA=

# ─── ICICI Production Endpoints ───────────────────────────────────────────────
ICICI_BASE_URL=https://pgpay.icicibank.com
ICICI_INITIATE_SALE_URL=https://pgpay.icicibank.com/pg/api/v2/initiateSale
ICICI_COMMAND_URL=https://pgpay.icicibank.com/pg/api/command

# ─── Merchant Info ────────────────────────────────────────────────────────────
MERCHANT_NAME=M/S.ROOKS AND BROOKS TECHNOLOGIES PRIVATE LIMITED

# Firebase paymentCallback Cloud Function URL (deployed)
# RETURN_URL  → ICICI redirects user's browser here after payment
# NOTIFICATION_URL → ICICI POSTs server-side result here (webhook)
MERCHANT_RETURN_URL=https://paymentcallback-ltjv3mr7da-uc.a.run.app
MERCHANT_NOTIFICATION_URL=https://paymentcallback-ltjv3mr7da-uc.a.run.app

# ─── Firebase Config ──────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=white-label-app-33300
FIREBASE_PRIVATE_KEY=<FIREBASE_PRIVATE_KEY>
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@white-label-app-33300.iam.gserviceaccount.com

# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ─── SMTP (Email) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=support@rookstechnologies.com
SMTP_PASS=<SMTP_PASSWORD>
